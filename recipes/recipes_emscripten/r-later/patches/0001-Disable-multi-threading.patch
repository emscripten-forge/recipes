diff --git a/configure b/configure
index aa9a93f..f8aa1c0 100755
--- a/configure
+++ b/configure
@@ -20,6 +20,12 @@ else
   EXTRA_PKG_LIBS=-latomic
 fi
 
+echo "Building single-threaded later."
+unset EXTRA_PKG_LIBS
+PKG_CPPFLAGS="-DLATER_SINGLE_THREADED"
+PKG_PTHREAD_CPPFLAGS=""
+PKG_PTHREAD_LIBS=""
+
 case "$CC" in
   *undefined*)
     echo "Found UBSAN. Will skip tests that raise false positives."
@@ -28,7 +34,10 @@ case "$CC" in
 esac
 
 # Write to Makevars
-sed -e "s|@extra_pkg_libs@|$EXTRA_PKG_LIBS|" -e "s|@pkg_cppflags@|$PKG_CPPFLAGS|" \
+sed -e "s|@extra_pkg_libs@|$EXTRA_PKG_LIBS|" \
+    -e "s|@pkg_cppflags@|$PKG_CPPFLAGS|" \
+    -e "s|@pkg_pthread_cppflags@|$PKG_PTHREAD_CPPFLAGS|" \
+    -e "s|@pkg_pthread_libs@|$PKG_PTHREAD_LIBS|" \
     src/Makevars.in > src/Makevars
 
 # Success
