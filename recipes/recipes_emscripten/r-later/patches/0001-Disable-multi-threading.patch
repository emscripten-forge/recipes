--- a/inst/include/later_api.h
+++ b/inst/include/later_api.h
@@ -26,7 +26,9 @@
 #include <windows.h>
 #else // _WIN32
 #include <poll.h>
+#if !defined(__EMSCRIPTEN__) && !defined(LATER_SINGLE_THREADED)
 #include <pthread.h>
