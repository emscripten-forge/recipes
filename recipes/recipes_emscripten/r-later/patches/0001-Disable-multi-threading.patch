+    Rf_error("later::BackgroundTask is not supported in single-threaded builds");
+#elif defined(_WIN32)
     HANDLE hThread = ::CreateThread(
       NULL, 0,
       BackgroundTask::task_main_win,
@@ -181,6 +178,13 @@ public:
       NULL
     );
     ::CloseHandle(hThread);
+#else
+    pthread_attr_t attr;
+    pthread_attr_init(&attr);
+    pthread_attr_setdetachstate(&attr, PTHREAD_CREATE_DETACHED);
+    pthread_t t;
+    pthread_create(&t, &attr, BackgroundTask::task_main, this);
+    pthread_attr_destroy(&attr);
 #endif
   }
 
diff --git a/src/Makevars.in b/src/Makevars.in
index f7be559..fa5638c 100644
--- a/src/Makevars.in
+++ b/src/Makevars.in
@@ -1,5 +1,11 @@
-PKG_CPPFLAGS = -pthread -DSTRICT_R_HEADERS -DRCPP_NO_MODULES @pkg_cppflags@
-PKG_LIBS = -pthread @extra_pkg_libs@
+PKG_CPPFLAGS = @pkg_pthread_cppflags@ -DSTRICT_R_HEADERS -DRCPP_NO_MODULES @pkg_cppflags@
+PKG_LIBS = @pkg_pthread_libs@ @extra_pkg_libs@
+
+# -pthread enables shared memory and breaks SIDE_MODULE load.
+ifneq (,$(findstring emcc,$(CC)))
+PKG_CPPFLAGS := $(filter-out -pthread,$(PKG_CPPFLAGS))
+PKG_LIBS := $(filter-out -pthread,$(PKG_LIBS))
+endif
 
 #### Debugging flags ####
 # Uncomment to enable thread assertions
