             CBLAS_INT ml = iwm[0];
             CBLAS_INT mu = iwm[1];
             CBLAS_INT meband = 2 * ml + mu + 1;
-            BLAS_FUNC(zgbtrs)("N", &(CBLAS_INT){S->n}, &ml, &mu, &int1, wm, &meband, &iwm[30], x, &(CBLAS_INT){S->n}, &ier);
+            BLAS_FUNC(zgbtrs)("N", &(CBLAS_INT){S->n}, &ml, &mu, &int1, wm, &meband, &iwm[30], x, &(CBLAS_INT){S->n}, &ier, 1);
             break;
