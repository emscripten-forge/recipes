From 8968781c4ee4d9dc98c19aea6304adb0659c3930 Mon Sep 17 00:00:00 2001
From: Isabel Paredes <isabel.paredes@quantstack.net>
Date: Mon, 1 Jun 2026 13:40:10 +0200
Subject: [PATCH 2/2] Fix lapack function signatures

---
 src/vendor/cigraph/src/linalg/lapack.c        | 22 ++++++++++------
 .../cigraph/src/linalg/lapack_internal.h      | 25 +++++++++++--------
 2 files changed, 29 insertions(+), 18 deletions(-)

diff --git a/src/vendor/cigraph/src/linalg/lapack.c b/src/vendor/cigraph/src/linalg/lapack.c
index ed5d64c..8ff153b 100644
--- a/src/vendor/cigraph/src/linalg/lapack.c
+++ b/src/vendor/cigraph/src/linalg/lapack.c
@@ -225,7 +225,7 @@ igraph_error_t igraph_lapack_dgetrs(igraph_bool_t transpose, const igraph_matrix
     IGRAPH_CHECK(igraph_vector_int_copy_to_fortran(ipiv, &vipiv));
 
     igraphdgetrs_(&trans, &n, &nrhs, VECTOR(a->data), &lda, VECTOR(vipiv),
-                  VECTOR(b->data), &ldb, &info);
+                  VECTOR(b->data), &ldb, &info, /*trans_len=*/ 1);
 
     igraph_vector_fortran_int_destroy(&vipiv);
     IGRAPH_FINALLY_CLEAN(1);
@@ -514,7 +514,8 @@ igraph_error_t igraph_lapack_dsyevr(const igraph_matrix_t *A,
     igraphdsyevr_(&jobz, &range, &uplo, &n, &MATRIX(Acopy, 0, 0), &lda,
                   &vl, &vu, &il, &iu, &abstol, &m, VECTOR(*myvalues),
                   vectors ? &MATRIX(*vectors, 0, 0) : 0, &ldz, VECTOR(mysupport),
-                  VECTOR(work), &lwork, VECTOR(iwork), &liwork, &info);
+                  VECTOR(work), &lwork, VECTOR(iwork), &liwork, &info,
+                  /*jobz_len=*/ 1, /*range_len=*/ 1, /*uplo_len=*/ 1);
 
     if (info != 0) {
         IGRAPH_ERROR("Invalid argument to dsyevr in workspace query.", IGRAPH_EINVAL);
@@ -528,7 +529,8 @@ igraph_error_t igraph_lapack_dsyevr(const igraph_matrix_t *A,
     igraphdsyevr_(&jobz, &range, &uplo, &n, &MATRIX(Acopy, 0, 0), &lda,
                   &vl, &vu, &il, &iu, &abstol, &m, VECTOR(*myvalues),
                   vectors ? &MATRIX(*vectors, 0, 0) : 0, &ldz, VECTOR(mysupport),
-                  VECTOR(work), &lwork, VECTOR(iwork), &liwork, &info);
+                  VECTOR(work), &lwork, VECTOR(iwork), &liwork, &info,
+                  /*jobz_len=*/ 1, /*range_len=*/ 1, /*uplo_len=*/ 1);
 
     if (info != 0) {
         IGRAPH_ERROR("Invalid argument to dsyevr in calculation.", IGRAPH_EINVAL);
@@ -672,7 +674,8 @@ igraph_error_t igraph_lapack_dgeev(const igraph_matrix_t *A,
                  VECTOR(*myreal), VECTOR(*myimag),
                  vectorsleft  ? &MATRIX(*vectorsleft, 0, 0) : &dummy, &ldvl,
                  vectorsright ? &MATRIX(*vectorsright, 0, 0) : &dummy, &ldvr,
-                 VECTOR(work), &lwork, info);
+                 VECTOR(work), &lwork, info,
+                 /*jobvl_len=*/ 1, /*jobvr_len=*/ 1);
 
     lwork = (int) VECTOR(work)[0];
     IGRAPH_CHECK(igraph_vector_resize(&work, lwork));
@@ -681,7 +684,8 @@ igraph_error_t igraph_lapack_dgeev(const igraph_matrix_t *A,
                  VECTOR(*myreal), VECTOR(*myimag),
                  vectorsleft  ? &MATRIX(*vectorsleft, 0, 0) : &dummy, &ldvl,
                  vectorsright ? &MATRIX(*vectorsright, 0, 0) : &dummy, &ldvr,
-                 VECTOR(work), &lwork, info);
+                 VECTOR(work), &lwork, info,
+                 /*jobvl_len=*/ 1, /*jobvr_len=*/ 1);
 
     if (*info < 0) {
         IGRAPH_ERROR("Cannot calculate eigenvalues (dgeev).", IGRAPH_ELAPACK);
@@ -938,7 +942,9 @@ igraph_error_t igraph_lapack_dgeevx(igraph_lapack_dgeevx_balance_t balance,
                   ilo, ihi, VECTOR(*myscale), abnrm,
                   rconde ? VECTOR(*rconde) : &dummy,
                   rcondv ? VECTOR(*rcondv) : &dummy,
-                  VECTOR(work), &lwork, VECTOR(iwork), info);
+                  VECTOR(work), &lwork, VECTOR(iwork), info,
+                  /*balanc_len=*/ 1, /*jobvl_len=*/ 1, /*jobvr_len=*/ 1,
+                  /*sense_len=*/ 1);
 
     lwork = (int) VECTOR(work)[0];
     IGRAPH_CHECK(igraph_vector_resize(&work, lwork));
@@ -950,7 +956,9 @@ igraph_error_t igraph_lapack_dgeevx(igraph_lapack_dgeevx_balance_t balance,
                   ilo, ihi, VECTOR(*myscale), abnrm,
                   rconde ? VECTOR(*rconde) : &dummy,
                   rcondv ? VECTOR(*rcondv) : &dummy,
-                  VECTOR(work), &lwork, VECTOR(iwork), info);
+                  VECTOR(work), &lwork, VECTOR(iwork), info,
+                  /*balanc_len=*/ 1, /*jobvl_len=*/ 1, /*jobvr_len=*/ 1,
+                  /*sense_len=*/ 1);
 
     if (*info < 0) {
         IGRAPH_ERROR("Cannot calculate eigenvalues (dgeev).", IGRAPH_ELAPACK);
