 class GroupMixinLibGAP:
     def __contains__(self, elt) -> bool:
@@ -341,7 +343,6 @@ class GroupMixinLibGAP:
             sage: list(chi)                                                             # needs sage.rings.number_field
             [0, 1, 2, 3, 4, 5, 6, 7]
