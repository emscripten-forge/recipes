 src/sage/groups/libgap_mixin.py | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/src/sage/groups/libgap_mixin.py b/src/sage/groups/libgap_mixin.py
index b26e33ef792..0a01d374a29 100644
