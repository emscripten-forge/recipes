+if(EMSCRIPTEN)
+  # On Emscripten, ORC JIT is unavailable.  Build the Wasm Execution Engine
+  # using lld::lldMain (same approach as clang-repl's Wasm backend).
+  # lldWasm provides the wasm driver; lldCommon provides lldMain itself.
+  # find_package(LLD) and include_directories(LLD_INCLUDE_DIRS) are done at
