diff --git a/mlir/CMakeLists.txt b/mlir/CMakeLists.txt
index 9e1e9314511e..77353eff0bd3 100644
--- a/mlir/CMakeLists.txt
+++ b/mlir/CMakeLists.txt
@@ -14,6 +14,28 @@ if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR)
   set(MLIR_STANDALONE_BUILD TRUE)
 endif()
 
+# Emscripten does not support shared libraries by default.  Override the global
+# property early (after project() so the toolchain has already run) so that
+# nanobind MODULE libraries are linked with emcc as wasm SIDE_MODULEs instead
+# of being archived as static libs.  Must be set before any add_library() call.
+if(EMSCRIPTEN)
+  set_property(GLOBAL PROPERTY TARGET_SUPPORTS_SHARED_LIBS TRUE)
+  # Use the llvmlite pattern: inject SIDE_MODULE=1 via the CREATE_CXX_FLAGS
+  # variables so every SHARED target is linked as a wasm SIDE_MODULE.
+  # nanobind creates MODULE targets (not SHARED), which use CMAKE_MODULE_LINKER_FLAGS
+  # for their LINK_FLAGS — keep that separately so Python extensions also get the flag.
+  set(CMAKE_SHARED_LIBRARY_CREATE_C_FLAGS   "-s SIDE_MODULE=1")
+  set(CMAKE_SHARED_LIBRARY_CREATE_CXX_FLAGS "-s SIDE_MODULE=1")
+  set(CMAKE_MODULE_LINKER_FLAGS "-s SIDE_MODULE=1" CACHE STRING "" FORCE)
+  set(CMAKE_STRIP FALSE)
+  # Pre-set NB_SUFFIX as INTERNAL cache — nanobind cmake checks DEFINED CACHE{NB_SUFFIX}
+  # before querying the native Python executable for the extension suffix.  The
+  # placeholder version (313) is updated dynamically in MLIRDetectPythonEnv.cmake
+  # once find_package(Python3) has set Python3_VERSION_MAJOR/MINOR.
+  set(NB_SUFFIX ".cpython-313-wasm32-emscripten.so" CACHE INTERNAL "" FORCE)
+  set(NB_SUFFIX_S ".abi3.so" CACHE INTERNAL "" FORCE)
+endif()
+
 # Must go below project(..)
 include(GNUInstallDirs)
 set(CMAKE_CXX_STANDARD 17 CACHE STRING "C++ standard to conform to")
@@ -32,6 +54,23 @@ if(MLIR_STANDALONE_BUILD)
 
   include_directories(${LLVM_INCLUDE_DIRS})
 
+  # On Emscripten, cmake imported targets (lldWasm, lldCommon) should resolve to
+  # full library paths.  As a safety net for local builds where wasm-ld may not
+  # find them by name, add the host-prefix lib dir to the module linker search path.
+  # LLVM_LIBRARY_DIR is set by find_package(LLVM) above.
+  # Note: the recipe CI has $PREFIX/lib in the default wasm-ld search path so this
+  # is effectively a no-op there.
+  if(EMSCRIPTEN)
+    # find_package(LLD) here (top level) so the imported targets lldWasm / lldCommon
+    # are globally visible.  If called only from a subdirectory (e.g.
+    # lib/CAPI/ExecutionEngine/), cmake-imported targets are scoped to that
+    # directory and siblings like python/ cannot resolve them — falling back to
+    # the -l flag form which wasm-ld then cannot find.
+    find_package(LLD REQUIRED CONFIG)
+    include_directories(${LLD_INCLUDE_DIRS})
+    string(APPEND CMAKE_MODULE_LINKER_FLAGS " --library-path=${LLVM_LIBRARY_DIR}")
+  endif()
+
   set(CMAKE_LIBRARY_OUTPUT_DIRECTORY
     "${CMAKE_CURRENT_BINARY_DIR}/lib${LLVM_LIBDIR_SUFFIX}")
   set(CMAKE_RUNTIME_OUTPUT_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/bin")
diff --git a/mlir/cmake/modules/MLIRDetectPythonEnv.cmake b/mlir/cmake/modules/MLIRDetectPythonEnv.cmake
index 01dd7437cc8f..7a549b81c843 100644
--- a/mlir/cmake/modules/MLIRDetectPythonEnv.cmake
+++ b/mlir/cmake/modules/MLIRDetectPythonEnv.cmake
@@ -43,6 +43,21 @@ macro(mlir_configure_python_dev_packages)
     find_package(Python ${MLIR_MINIMUM_PYTHON_VERSION}
       COMPONENTS Interpreter ${_python_development_component} REQUIRED)
 
+    # On Emscripten the Python executable is the native build-host Python, so
+    # find_package reports the host (darwin/linux) SOABI.  Override with the
+    # correct wasm32 value now that VERSION_MAJOR/MINOR are known.  Also refresh
+    # NB_SUFFIX in the cache so nanobind (found below) uses the right suffix
+    # without querying the native Python.
+    if(EMSCRIPTEN)
+      set(Python3_SOABI
+          "cpython-${Python3_VERSION_MAJOR}${Python3_VERSION_MINOR}-wasm32-emscripten")
+      set(Python_SOABI
+          "cpython-${Python3_VERSION_MAJOR}${Python3_VERSION_MINOR}-wasm32-emscripten")
+      set(NB_SUFFIX
+          ".cpython-${Python3_VERSION_MAJOR}${Python3_VERSION_MINOR}-wasm32-emscripten.so"
+          CACHE INTERNAL "" FORCE)
+    endif()
+
     unset(_python_development_component)
     message(STATUS "Found python include dirs: ${Python3_INCLUDE_DIRS}")
     message(STATUS "Found python libraries: ${Python3_LIBRARIES}")
