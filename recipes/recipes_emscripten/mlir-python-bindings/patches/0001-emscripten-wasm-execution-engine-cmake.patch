+    native
+    orcjit
+    support
+  )
+
+  # Main API shared library.
+  # PARTIAL_SOURCES_INTENDED: WasmExecutionEngine.cpp stays uncompiled on native.
+  add_mlir_upstream_c_api_library(MLIRCAPIExecutionEngine
+    ExecutionEngine.cpp
+
+    PARTIAL_SOURCES_INTENDED
+
+    LINK_LIBS PUBLIC
+    MLIRBuiltinToLLVMIRTranslation
+    MLIRExecutionEngine
+    MLIRLLVMToLLVMIRTranslation
+  )
+endif()
diff --git a/mlir/python/CMakeLists.txt b/mlir/python/CMakeLists.txt
index 003a06b16daa..867f2c3b90b2 100644
--- a/mlir/python/CMakeLists.txt
+++ b/mlir/python/CMakeLists.txt
@@ -45,6 +45,7 @@ declare_mlir_python_sources(MLIRPythonSources.ExecutionEngine
   ADD_TO_PARENT MLIRPythonSources
   SOURCES
     execution_engine.py
+    wasm_execution_engine.py
     _mlir_libs/_mlirExecutionEngine.pyi
   SOURCES_GLOB
     runtime/*.py
@@ -714,6 +715,21 @@ if(MLIR_ENABLE_EXECUTION_ENGINE)
     EMBED_CAPI_LINK_LIBS
       MLIRCAPIExecutionEngine
   )
+elseif(EMSCRIPTEN)
+  # On Emscripten, ORC JIT is unavailable; expose the Wasm Execution Engine
+  # instead.  The Python-side module name matches the eudsl convention so that
+  # wasm_execution_engine.py can import _mlirWasmExecutionEngine unchanged.
+  declare_mlir_python_extension(MLIRPythonExtension.WasmExecutionEngine
+    MODULE_NAME _mlirWasmExecutionEngine
+    ADD_TO_PARENT MLIRPythonSources.ExecutionEngine
+    ROOT_DIR "${PYTHON_SOURCE_DIR}"
+    SOURCES
+      WasmExecutionEngineModule.cpp
+    PRIVATE_LINK_LIBS
+      LLVMSupport
+    EMBED_CAPI_LINK_LIBS
+      MLIRCAPIWasmExecutionEngine
+  )
 endif()
 
 declare_mlir_python_extension(MLIRPythonExtension.GPUDialectPasses
