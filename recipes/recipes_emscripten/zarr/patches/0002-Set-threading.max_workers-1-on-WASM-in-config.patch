From 7c8d01bf4d63c0baa58592b6273d56b1507a18b4 Mon Sep 17 00:00:00 2001
From: Agriya Khetarpal <74401230+agriyakhetarpal@users.noreply.github.com>
Date: Sun, 17 May 2026 21:10:19 +0530
Subject: [PATCH 2/3] Set threading.max_workers=1 on WASM in config

WASM environments are single-threaded; spawning multiple worker threads
causes hangs or errors under Pyodide. Setting max_workers to 1 on WASM
constrains zarr's thread pool to a single worker, which matches the
execution model of the Emscripten runtime.

Upstream reference: https://github.com/zarr-developers/zarr-python/pull/1903
---
 src/zarr/core/config.py | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/zarr/core/config.py b/src/zarr/core/config.py
index 7dcbc78e..d6656556 100644
--- a/src/zarr/core/config.py
+++ b/src/zarr/core/config.py
@@ -33,6 +33,8 @@ from typing import TYPE_CHECKING, Any, Literal, cast
 
 from donfig import Config as DConfig
 
+from zarr._constants import IS_WASM
+
 if TYPE_CHECKING:
     from donfig.config_obj import ConfigSet
 
@@ -101,7 +103,7 @@ config = Config(
                 "rectilinear_chunks": False,
             },
             "async": {"concurrency": 10, "timeout": None},
-            "threading": {"max_workers": None},
+            "threading": {"max_workers": 1 if IS_WASM else None},
             "json_indent": 2,
             "codec_pipeline": {
                 "path": "zarr.core.codec_pipeline.BatchedCodecPipeline",
-- 
