+# Emscripten: enable SHARED library support (SIDE_MODULE) explicitly.
+# The Emscripten.cmake toolchain does not always set TARGET_SUPPORTS_SHARED_LIBS
+# on all platforms/emsdk versions; without this cmake silently falls back to STATIC.
+if(EMSCRIPTEN)
+    set_property(GLOBAL PROPERTY TARGET_SUPPORTS_SHARED_LIBS TRUE)
+    set(CMAKE_SHARED_LIBRARY_CREATE_C_FLAGS   "-s SIDE_MODULE=1")
+    set(CMAKE_SHARED_LIBRARY_CREATE_CXX_FLAGS "-s SIDE_MODULE=1")
