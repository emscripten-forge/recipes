+def _is_emscripten_build():
+    """True when cross-compiling for Emscripten (emscripten-forge / emsdk)."""
+    return bool(os.environ.get('EMSCRIPTEN') or os.environ.get('EM_CONFIG')
+                or os.environ.get('EMSDK'))
+
+
+def _cmake_prefix():
+    """
+    Return the cmake command prefix list.
+    On Emscripten: ['emcmake', '/path/to/cmake']
+    Otherwise:     ['cmake']
+    """
+    if _is_emscripten_build():
+        build_prefix = os.environ.get('BUILD_PREFIX', '')
+        cmake_bin = (os.path.join(build_prefix, 'bin', 'cmake')
+                     if build_prefix else 'cmake')
+        return ['emcmake', cmake_bin]
+    return ['cmake']
+
+
+def _plain_cmake():
+    """
+    Return the bare cmake binary path (without emcmake prefix).
+    Used for the cmake --build step where emcmake is not needed.
+    """
+    if _is_emscripten_build():
+        build_prefix = os.environ.get('BUILD_PREFIX', '')
+        return (os.path.join(build_prefix, 'bin', 'cmake')
+                if build_prefix else 'cmake')
+    return 'cmake'
     # traceback is self explanatory.
 
 
