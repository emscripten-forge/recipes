index fe2692bf..5d55b45b 100644
--- a/llvmlite/binding/analysis.py
+++ b/llvmlite/binding/analysis.py
@@ -46,6 +46,33 @@ def view_dot_graph(graph, filename=None, view=False):
     - view [bool]: if True, opens the rendered output file.
 
     """
+    import sys
+    if sys.platform == 'emscripten':
+        # subprocess.Popen is unavailable on emscripten; render via
+        # @hpcc-js/wasm (a pure JS/WASM graphviz build) in the browser.
+        try:
+            from IPython.display import HTML
+            import uuid
+            div_id = 'cfg-' + uuid.uuid4().hex[:8]
+            dot_escaped = (graph
+                           .replace('\\', '\\\\')
+                           .replace('`', '\\`')
+                           .replace('$', '\\$'))
+            html = (
+                f'<div id="{div_id}"></div>\n'
+                '<script type="module">\n'
+                'import { Graphviz } from '
+                '"https://cdn.jsdelivr.net/npm/@hpcc-js/wasm@2/dist/index.js";\n'
+                'const graphviz = await Graphviz.load();\n'
+                f'document.getElementById("{div_id}").innerHTML = '
+                f'graphviz.dot(`{dot_escaped}`);\n'
+                '</script>'
+            )
+            return HTML(html)
+        except Exception:
+            from IPython.display import Code
+            return Code(graph, language='dot')
+
     # Optionally depends on graphviz package
     import graphviz as gv
 
